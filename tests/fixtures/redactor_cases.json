{
  "$comment": [
    "Shared redactor parity fixtures consumed by both:",
    "  - Python: tests/test_agent_install_state.py (redact_log_line)",
    "  - pwsh:   tests/pwsh/test_install_state_helpers.Tests.ps1 (Invoke-WinpodxRedact)",
    "Both implementations MUST produce byte-identical output on every case.",
    "",
    "Each case has:",
    "  id           — stable identifier for the case (used in test names)",
    "  description  — human-readable purpose of the case",
    "  input        — string fed to the redactor",
    "  expected     — exact string the redactor must return",
    "  must_not_contain — list of substrings that must be absent from the output (defense-in-depth)",
    "",
    "Pattern order (must match between Python and pwsh):",
    "  1. (?i)(net user\\s+\\S+\\s+)\\S+         -> $1<REDACTED>",
    "  2. (?i)(Authorization:\\s*Bearer\\s+)\\S+ -> $1<REDACTED>",
    "  3. (?i)\\b(password|token|apikey|api_key)\\s*=\\s*([^\\s'\"&]+) -> $1=<REDACTED>",
    "  4. (?<![A-Za-z0-9+/=])[A-Za-z0-9+/]{40,}={0,2}(?![A-Za-z0-9+/=]) -> <BASE64-REDACTED>",
    "",
    "When adding a case: add it once here. Both test suites pick it up automatically."
  ],
  "cases": [
    {
      "id": "empty_string",
      "description": "Empty input passes through unchanged.",
      "input": "",
      "expected": "",
      "must_not_contain": []
    },
    {
      "id": "plain_text_unchanged",
      "description": "Plain text with no secrets is left alone.",
      "input": "step=multi_session attempt=1 starting...",
      "expected": "step=multi_session attempt=1 starting...",
      "must_not_contain": ["<REDACTED>", "<BASE64-REDACTED>"]
    },
    {
      "id": "net_user_simple",
      "description": "net user <user> <pw> -> net user <user> <REDACTED> (username preserved).",
      "input": "net user kernalix7 SecretP@ss",
      "expected": "net user kernalix7 <REDACTED>",
      "must_not_contain": ["SecretP@ss"]
    },
    {
      "id": "net_user_case_insensitive",
      "description": "Match is case-insensitive on the literal 'net user'.",
      "input": "NET USER kernalix7 SecretP@ss",
      "expected": "NET USER kernalix7 <REDACTED>",
      "must_not_contain": ["SecretP@ss"]
    },
    {
      "id": "auth_bearer_simple",
      "description": "Authorization: Bearer <token> -> token replaced.",
      "input": "Authorization: Bearer abc123def456",
      "expected": "Authorization: Bearer <REDACTED>",
      "must_not_contain": ["abc123def456"]
    },
    {
      "id": "auth_bearer_case_insensitive",
      "description": "authorization / bearer literals match case-insensitively.",
      "input": "authorization: bearer ZZZTOKENZZZ",
      "expected": "authorization: bearer <REDACTED>",
      "must_not_contain": ["ZZZTOKENZZZ"]
    },
    {
      "id": "kv_password_amp_terminator",
      "description": "password=... terminates at &; the trailing key=value is preserved.",
      "input": "foo password=p@ssw0rd&other=keep",
      "expected": "foo password=<REDACTED>&other=keep",
      "must_not_contain": ["p@ssw0rd"]
    },
    {
      "id": "kv_token_uppercase",
      "description": "TOKEN= matches case-insensitively.",
      "input": "TOKEN=xyz extra",
      "expected": "TOKEN=<REDACTED> extra",
      "must_not_contain": ["xyz "]
    },
    {
      "id": "kv_apikey_lower",
      "description": "apikey= matches.",
      "input": "apikey=hunter2",
      "expected": "apikey=<REDACTED>",
      "must_not_contain": ["hunter2"]
    },
    {
      "id": "kv_apikey_mixed",
      "description": "ApiKey= matches.",
      "input": "ApiKey=hunter2",
      "expected": "ApiKey=<REDACTED>",
      "must_not_contain": ["hunter2"]
    },
    {
      "id": "kv_api_key_underscore_upper",
      "description": "API_KEY= (with underscore) matches.",
      "input": "API_KEY=hunter2",
      "expected": "API_KEY=<REDACTED>",
      "must_not_contain": ["hunter2"]
    },
    {
      "id": "base64_60_chars",
      "description": "60-char base64-ish blob redacted to <BASE64-REDACTED>.",
      "input": "prefix AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA suffix",
      "expected": "prefix <BASE64-REDACTED> suffix",
      "must_not_contain": ["AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"]
    },
    {
      "id": "base64_boundary_40_chars",
      "description": "40-char blob is exactly at the threshold and gets redacted.",
      "input": "BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB",
      "expected": "<BASE64-REDACTED>",
      "must_not_contain": ["BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB"]
    },
    {
      "id": "base64_below_threshold_passes",
      "description": "39-char blob is under the threshold and passes through unchanged.",
      "input": "CCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCC",
      "expected": "CCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCC",
      "must_not_contain": ["<BASE64-REDACTED>"]
    },
    {
      "id": "multi_pattern_bearer_and_password",
      "description": "Bearer token AND password= on same line both redacted.",
      "input": "Authorization: Bearer abc123 password=hunter2",
      "expected": "Authorization: Bearer <REDACTED> password=<REDACTED>",
      "must_not_contain": ["abc123 ", "hunter2"]
    },
    {
      "id": "net_user_then_base64",
      "description": "net user pw is redacted via the net-user rule, not the base64 rule.",
      "input": "net user kernalix7 ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnop",
      "expected": "net user kernalix7 <REDACTED>",
      "must_not_contain": ["ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnop", "<BASE64-REDACTED>"]
    },
    {
      "id": "bearer_with_long_base64_token",
      "description": "Bearer's ${token} swallows the base64 blob via the bearer rule first.",
      "input": "Authorization: Bearer ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnop",
      "expected": "Authorization: Bearer <REDACTED>",
      "must_not_contain": ["ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnop", "<BASE64-REDACTED>"]
    },
    {
      "id": "kv_password_quote_terminator_double",
      "description": "password= terminates at a double-quote.",
      "input": "args=\"password=p@ss\" trailing",
      "expected": "args=\"password=<REDACTED>\" trailing",
      "must_not_contain": ["p@ss\""]
    },
    {
      "id": "kv_password_quote_terminator_single",
      "description": "password= terminates at a single-quote.",
      "input": "args='password=p@ss' trailing",
      "expected": "args='password=<REDACTED>' trailing",
      "must_not_contain": ["p@ss'"]
    },
    {
      "id": "base64_inside_url_path_not_redacted",
      "description": "Short base64-ish path components below threshold are not redacted.",
      "input": "GET /api/v1/abc HTTP/1.1",
      "expected": "GET /api/v1/abc HTTP/1.1",
      "must_not_contain": ["<BASE64-REDACTED>"]
    },
    {
      "id": "base64_with_padding",
      "description": "Base64 blob with trailing = padding is redacted when the blob is not adjacent to base64-alphabet chars (the lookbehind requires it).",
      "input": "blob: AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA== end",
      "expected": "blob: <BASE64-REDACTED> end",
      "must_not_contain": ["AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"]
    },
    {
      "id": "literal_REDACTED_in_input_passes",
      "description": "If input already contains <REDACTED>, the redactor leaves it alone.",
      "input": "password=<REDACTED>",
      "expected": "password=<REDACTED>",
      "must_not_contain": []
    },
    {
      "id": "windows_path_unaffected",
      "description": "Windows-style paths are not falsely redacted.",
      "input": "C:\\winpodx\\install-state\\rdprrap_installed.done",
      "expected": "C:\\winpodx\\install-state\\rdprrap_installed.done",
      "must_not_contain": ["<REDACTED>", "<BASE64-REDACTED>"]
    },
    {
      "id": "uuid_unaffected",
      "description": "Standard UUIDs are below the base64 threshold and have hyphens, so they pass through.",
      "input": "session_id=abcd1234-1111-2222-3333-444455556666",
      "expected": "session_id=abcd1234-1111-2222-3333-444455556666",
      "must_not_contain": ["<BASE64-REDACTED>"]
    },
    {
      "id": "sha256_hex_unaffected",
      "description": "Hex-only digests (no +/) below 40 chars pass through.",
      "input": "sha256:abc123def456abc123def456abc123de",
      "expected": "sha256:abc123def456abc123def456abc123de",
      "must_not_contain": ["<BASE64-REDACTED>"]
    },
    {
      "id": "long_hex_64_redacted",
      "description": "64-char hex digest IS in the [A-Za-z0-9+/] alphabet and meets the 40+ length, so it is redacted as base64. Blob must be space-delimited from any preceding base64-alphabet char (lookbehind).",
      "input": "sha256 abc123def456abc123def456abc123def456abc123def456abc123def4561234",
      "expected": "sha256 <BASE64-REDACTED>",
      "must_not_contain": ["abc123def456abc123def456abc123def456abc123def456abc123def4561234"]
    }
  ]
}
